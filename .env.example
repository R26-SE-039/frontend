# Browser-facing API bases. In local Vite dev these should stay relative so requests go through the dev proxy and avoid CORS.
VITE_FAILURE_ANALYSIS_API_BASE_URL=/failure-api
VITE_REPAIR_AGENT_API_BASE_URL=/repair-agent-api

# Vite dev-server proxy targets. These are read by vite.config.ts and are not exposed to browser code.
FAILURE_ANALYSIS_PROXY_TARGET=http://127.0.0.1:8000
REPAIR_AGENT_PROXY_TARGET=http://127.0.0.1:8010
